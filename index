<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MS&amp;T • Medical Services &amp; Training Booking Portal</title>
    
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&amp;family=Space+Grotesk:wght@500;600&amp;display=swap');
        
        :root {
            --primary: #0f766e;
        }
        
        body {
            font-family: 'Inter', system_ui, sans-serif;
        }
        
        .font-display {
            font-family: 'Space Grotesk', 'Inter', sans-serif;
            font-weight: 600;
        }

        .medical-gradient {
            background: linear-gradient(135deg, #0f766e 0%, #134e4b 100%);
        }

        .section-header {
            font-size: 1.1rem;
            letter-spacing: -.025em;
        }

        .nav-active {
            background-color: #0f766e;
            color: white;
            border-radius: 0.5rem;
        }

        .course-badge {
            font-size: 0.75rem;
            padding: 0.125rem 0.5rem;
            border-radius: 9999px;
            font-weight: 600;
        }

        .wmfr { background-color: #fef3c7; color: #92400e; }
        .sfa { background-color: #dbeafe; color: #1e40af; }
        .bcls { background-color: #dcfce7; color: #166534; }

        .slot-bar {
            height: 6px;
            background: linear-gradient(to right, #0f766e var(--percent), #e5e7eb var(--percent));
            border-radius: 9999px;
        }

        .calendar-day {
            transition: all 0.1s ease;
        }
        
        .calendar-day:hover {
            background-color: #f1f5f9;
        }
        
        .calendar-day.has-events {
            background-color: #f0fdfa;
        }
        
        .calendar-day.today {
            background-color: #ccfbf1;
            font-weight: 700;
        }

        .session-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .session-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05), 0 4px 6px -4px rgb(0 0 0 / 0.05);
        }

        .data-table th {
            font-weight: 600;
            color: #334155;
            background-color: #f8fafc;
        }

        .modal {
            animation: modalPopIn 0.2s ease forwards;
        }

        @keyframes modalPopIn {
            from { opacity: 0; transform: scale(0.95) translateY(10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        .toast {
            animation: toastSlideIn 0.3s ease forwards;
        }

        .nav-tab {
            position: relative;
        }
        
        .nav-tab.active::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 100%;
            height: 3px;
            background-color: #0f766e;
        }

        .mini-badge {
            font-size: 0.65rem;
            padding: 1px 6px;
            border-radius: 4px;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800">
    <!-- Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-screen-xl mx-auto">
            <div class="px-8 py-4 flex items-center justify-between">
                <div class="flex items-center gap-x-3">
                    <div class="w-11 h-11 medical-gradient rounded-2xl flex items-center justify-center shadow-inner">
                        <i class="fa-solid fa-heart-pulse text-white text-3xl"></i>
                    </div>
                    <div>
                        <h1 class="font-display text-3xl tracking-tighter font-semibold text-slate-900">MS&amp;T</h1>
                        <p class="text-[10px] text-teal-700 -mt-1 font-medium tracking-[1.5px]">MEDICAL SERVICES &amp; TRAINING</p>
                    </div>
                    <div class="ml-3 pl-3 border-l border-slate-200">
                        <p class="text-sm font-semibold text-slate-700">Course Booking Portal</p>
                        <p class="text-xs text-slate-500">Internal Use • Singapore</p>
                    </div>
                </div>
                
                <div class="flex items-center gap-x-2">
                    <!-- User indicator -->
                    <div class="flex items-center gap-x-2 bg-slate-100 rounded-3xl pl-1 pr-4 py-1 text-sm">
                        <div class="w-8 h-8 bg-teal-600 rounded-full flex items-center justify-center text-white text-xs font-bold">RW</div>
                        <div class="leading-none">
                            <p class="font-medium text-sm">Ridzwan W.</p>
                            <p class="text-[10px] text-slate-500">Training Coordinator</p>
                        </div>
                    </div>
                    
                    <button class="flex items-center gap-x-2 px-4 py-2 text-sm font-medium rounded-3xl border border-slate-300 hover:bg-slate-100 transition-colors">
                        <i class="fa-solid fa-user-shield mr-1.5"></i>
                        <span>Admin</span>
                    </button>
                </div>
            </div>
            
            <!-- Navigation Tabs -->
            <div class="px-8 border-t border-slate-100">
                <div class="flex gap-x-1 -mb-px">
                    <button id="tab-0" class="nav-tab active px-5 py-3 text-sm font-semibold flex items-center gap-x-2 text-teal-700 border-b-2 border-teal-700">
                        <i class="fa-solid fa-calendar-days w-4"></i>
                        <span>Upcoming Sessions</span>
                    </button>
                    <button id="tab-1" class="nav-tab px-5 py-3 text-sm font-semibold flex items-center gap-x-2 text-slate-600 hover:text-slate-800">
                        <i class="fa-solid fa-user-plus w-4"></i>
                        <span>My Bookings</span>
                    </button>
                    <button id="tab-2" class="nav-tab px-5 py-3 text-sm font-semibold flex items-center gap-x-2 text-slate-600 hover:text-slate-800">
                        <i class="fa-solid fa-chart-line w-4"></i>
                        <span>Reports</span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <div class="max-w-screen-xl mx-auto px-8 pt-6 pb-12">
        
        <!-- TAB 0: UPCOMING SESSIONS (User View) -->
        <div id="view-0" class="tab-view">
            <div class="flex items-end justify-between mb-5">
                <div>
                    <h2 class="text-3xl font-semibold tracking-tight">Upcoming Training Sessions</h2>
                    <p class="text-slate-600 mt-1">Book your place in our certified medical training programmes</p>
                </div>
                <div class="flex items-center gap-x-3">
                    <div class="bg-white border border-slate-200 rounded-3xl px-1 py-1 flex items-center text-sm shadow-sm">
                        <button id="btn-list-view" class="px-4 py-1.5 rounded-3xl flex items-center gap-x-2 text-sm font-medium bg-teal-600 text-white">
                            <i class="fa-solid fa-list"></i>
                            <span>List</span>
                        </button>
                        <button id="btn-calendar-view" class="px-4 py-1.5 rounded-3xl flex items-center gap-x-2 text-sm font-medium text-slate-600 hover:bg-slate-50">
                            <i class="fa-solid fa-calendar"></i>
                            <span>Calendar</span>
                        </button>
                    </div>
                    <button class="px-4 py-2 text-sm flex items-center gap-x-2 rounded-3xl border border-slate-300 hover:bg-white transition-colors">
                        <i class="fa-solid fa-undo text-xs"></i>
                        <span class="font-medium">Clear Filters</span>
                    </button>
                </div>
            </div>

            <!-- Filters -->
            <div class="bg-white border border-slate-200 rounded-3xl p-5 mb-6 shadow-sm">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
                    
                    <!-- Search -->
                    <div class="md:col-span-4">
                        <label class="block text-xs font-semibold text-slate-500 mb-1.5 tracking-wider">SEARCH</label>
                        <div class="relative">
                            <i class="fa-solid fa-search absolute left-4 top-3 text-slate-400"></i>
                            <input id="search-input" type="text" placeholder="Search course, venue or instructor..." class="w-full pl-11 pr-4 py-2.5 text-sm border border-slate-300 rounded-2xl focus:outline-none focus:border-teal-500">
                        </div>
                    </div>
                    
                    <!-- Course Type -->
                    <div class="md:col-span-3">
                        <label class="block text-xs font-semibold text-slate-500 mb-1.5 tracking-wider">COURSE TYPE</label>
                        <div class="flex flex-wrap gap-1.5" id="course-filters">
                            <!-- Populated by JS -->
                        </div>
                    </div>
                    
                    <!-- Date Range -->
                    <div class="md:col-span-3 grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 mb-1.5 tracking-wider">FROM DATE</label>
                            <input id="date-from" type="date" class="w-full text-sm border border-slate-300 rounded-2xl px-3 py-2 focus:outline-none focus:border-teal-500">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 mb-1.5 tracking-wider">TO DATE</label>
                            <input id="date-to" type="date" class="w-full text-sm border border-slate-300 rounded-2xl px-3 py-2 focus:outline-none focus:border-teal-500">
                        </div>
                    </div>
                    
                    <div class="md:col-span-2 flex justify-end">
                        <button class="w-full md:w-auto px-6 py-2.5 bg-teal-700 hover:bg-teal-800 transition-colors text-white text-sm font-semibold rounded-2xl flex items-center justify-center gap-x-2">
                            <i class="fa-solid fa-filter"></i>
                            <span>Apply</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Calendar View -->
            <div id="calendar-view" class="hidden mb-6">
                <div class="bg-white border border-slate-200 rounded-3xl p-5 shadow-sm">
                    <div class="flex items-center justify-between mb-4 px-2">
                        <div class="flex items-center gap-x-3">
                            <button class="w-9 h-9 flex items-center justify-center hover:bg-slate-100 rounded-2xl text-slate-600">
                                <i class="fa-solid fa-chevron-left"></i>
                            </button>
                            <h3 id="calendar-month" class="font-semibold text-xl w-44 text-center"></h3>
                            <button class="w-9 h-9 flex items-center justify-center hover:bg-slate-100 rounded-2xl text-slate-600">
                                <i class="fa-solid fa-chevron-right"></i>
                            </button>
                        </div>
                        <button class="text-xs px-3 py-1.5 rounded-2xl border border-slate-300 text-slate-600 hover:bg-slate-50 flex items-center gap-x-1">
                            <i class="fa-solid fa-calendar-day text-xs"></i>
                            <span>Today</span>
                        </button>
                    </div>
                    
                    <!-- Calendar Grid -->
                    <div class="grid grid-cols-7 gap-px bg-slate-200 rounded-2xl overflow-hidden border border-slate-200" id="calendar-grid">
                        <!-- Populated dynamically by JS -->
                    </div>
                    
                    <div class="flex items-center justify-center gap-x-6 mt-4 text-xs">
                        <div class="flex items-center gap-x-2"><span class="w-3 h-3 rounded bg-amber-200"></span> <span class="text-slate-600">WMFR</span></div>
                        <div class="flex items-center gap-x-2"><span class="w-3 h-3 rounded bg-blue-200"></span> <span class="text-slate-600">Standard First Aid</span></div>
                        <div class="flex items-center gap-x-2"><span class="w-3 h-3 rounded bg-emerald-200"></span> <span class="text-slate-600">BCLS + AED</span></div>
                    </div>
                </div>
            </div>

            <!-- List View -->
            <div id="list-view">
                <div class="bg-white border border-slate-200 rounded-3xl shadow-sm overflow-hidden">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-slate-200 bg-slate-50">
                                <th class="text-left px-6 py-4 text-xs font-semibold text-slate-500 w-36">DATE &amp; TIME</th>
                                <th class="text-left px-6 py-4 text-xs font-semibold text-slate-500">COURSE</th>
                                <th class="text-left px-6 py-4 text-xs font-semibold text-slate-500">VENUE</th>
                                <th class="text-left px-6 py-4 text-xs font-semibold text-slate-500">INSTRUCTOR(S)</th>
                                <th class="text-center px-6 py-4 text-xs font-semibold text-slate-500 w-40">AVAILABILITY</th>
                                <th class="text-right px-6 py-4 text-xs font-semibold text-slate-500 w-28">ACTION</th>
                            </tr>
                        </thead>
                        <tbody id="sessions-tbody" class="divide-y divide-slate-100 text-sm">
                            <!-- Populated by renderSessionsTable() -->
                        </tbody>
                    </table>
                </div>
                <div id="no-results" class="hidden text-center py-12">
                    <i class="fa-solid fa-calendar-xmark text-5xl text-slate-300 mb-4"></i>
                    <p class="font-medium text-slate-600">No sessions match your filters</p>
                    <button class="mt-3 text-teal-700 text-sm font-medium">Clear all filters</button>
                </div>
            </div>
        </div>

        <!-- TAB 1: MY BOOKINGS -->
        <div id="view-1" class="tab-view hidden">
            <div class="max-w-3xl">
                <h2 class="text-3xl font-semibold tracking-tight mb-1">My Bookings</h2>
                <p class="text-slate-600 mb-6">Enter your email address to view or manage your training registrations</p>
                
                <div class="bg-white border border-slate-200 rounded-3xl p-6 mb-6">
                    <div class="flex gap-x-3">
                        <div class="flex-1">
                            <label class="text-xs font-semibold tracking-wider text-slate-500 block mb-1.5">EMAIL ADDRESS</label>
                            <input id="my-email-input" type="email" placeholder="your.name@hospital.sg" class="w-full border border-slate-300 focus:border-teal-600 px-4 py-3 rounded-2xl text-sm">
                        </div>
                        <div class="pt-6">
                            <button class="px-8 py-3 bg-teal-700 hover:bg-teal-800 text-white rounded-2xl font-semibold text-sm flex items-center gap-x-2">
                                <i class="fa-solid fa-search"></i>
                                <span>Find My Bookings</span>
                            </button>
                        </div>
                    </div>
                </div>
                
                <div id="my-bookings-results" class="hidden">
                    <div class="flex items-center justify-between mb-3 px-1">
                        <h4 class="font-semibold flex items-center gap-x-2"><i class="fa-solid fa-ticket text-teal-600"></i> Your Registered Sessions</h4>
                        <span id="my-bookings-count" class="text-xs bg-teal-100 text-teal-700 px-3 py-1 rounded-3xl font-medium"></span>
                    </div>
                    
                    <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm">
                        <table class="w-full text-sm">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="px-5 py-3 text-left text-xs font-semibold text-slate-500">SESSION</th>
                                    <th class="px-5 py-3 text-left text-xs font-semibold text-slate-500">DATE</th>
                                    <th class="px-5 py-3 text-left text-xs font-semibold text-slate-500">VENUE</th>
                                    <th class="px-5 py-3 text-center text-xs font-semibold text-slate-500">STATUS</th>
                                    <th class="px-5 py-3 w-20"></th>
                                </tr>
                            </thead>
                            <tbody id="my-bookings-tbody" class="divide-y">
                                <!-- JS populated -->
                            </tbody>
                        </table>
                    </div>
                    
                    <p class="text-xs text-slate-500 mt-3 px-1">Need to make changes? Contact the training unit or cancel below. Cancellations must be made at least 5 working days before the course date.</p>
                </div>
            </div>
        </div>

        <!-- TAB 2: REPORTS (Public-ish summary) -->
        <div id="view-2" class="tab-view hidden">
            <h2 class="text-3xl font-semibold tracking-tight mb-6">Training Statistics</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
                <div class="bg-white border border-slate-200 rounded-3xl p-5">
                    <div class="flex justify-between">
                        <div>
                            <p class="text-xs text-slate-500 tracking-wider">UPCOMING SESSIONS</p>
                            <p id="stat-upcoming" class="text-4xl font-semibold text-teal-700 mt-1">12</p>
                        </div>
                        <i class="fa-solid fa-calendar-check text-4xl text-teal-100"></i>
                    </div>
                </div>
                <div class="bg-white border border-slate-200 rounded-3xl p-5">
                    <div class="flex justify-between">
                        <div>
                            <p class="text-xs text-slate-500 tracking-wider">TOTAL BOOKINGS</p>
                            <p id="stat-bookings" class="text-4xl font-semibold text-teal-700 mt-1">87</p>
                        </div>
                        <i class="fa-solid fa-users text-4xl text-teal-100"></i>
                    </div>
                </div>
                <div class="bg-white border border-slate-200 rounded-3xl p-5">
                    <div class="flex justify-between">
                        <div>
                            <p class="text-xs text-slate-500 tracking-wider">AVG. OCCUPANCY</p>
                            <p id="stat-occupancy" class="text-4xl font-semibold text-teal-700 mt-1">68%</p>
                        </div>
                        <i class="fa-solid fa-chart-pie text-4xl text-teal-100"></i>
                    </div>
                </div>
                <div class="bg-white border border-slate-200 rounded-3xl p-5">
                    <div class="flex justify-between">
                        <div>
                            <p class="text-xs text-slate-500 tracking-wider">MOST POPULAR</p>
                            <p id="stat-popular" class="text-xl font-semibold text-teal-700 mt-1 leading-none">Standard First Aid</p>
                        </div>
                        <i class="fa-solid fa-tachometer-alt text-4xl text-teal-100"></i>
                    </div>
                </div>
            </div>
            
            <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
                <!-- Chart -->
                <div class="lg:col-span-3 bg-white border border-slate-200 rounded-3xl p-6">
                    <h4 class="font-semibold mb-4 flex items-center gap-x-2"><i class="fa-solid fa-chart-bar text-teal-600"></i> Bookings by Course Type</h4>
                    <div class="h-72">
                        <canvas id="bookings-chart"></canvas>
                    </div>
                </div>
                
                <div class="lg:col-span-2 bg-white border border-slate-200 rounded-3xl p-6">
                    <h4 class="font-semibold mb-4">Quick Insights</h4>
                    <div class="space-y-4 text-sm">
                        <div class="flex justify-between items-center border-b pb-3">
                            <span class="text-slate-600">BCLS + AED fill rate</span>
                            <span class="font-semibold text-emerald-600">92%</span>
                        </div>
                        <div class="flex justify-between items-center border-b pb-3">
                            <span class="text-slate-600">WMFR remaining slots (Jul-Aug)</span>
                            <span class="font-semibold">18</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-600">Peak month</span>
                            <span class="font-semibold">August 2026</span>
                        </div>
                    </div>
                    
                    <div class="mt-6 pt-4 border-t">
                        <button class="text-sm w-full py-2.5 border border-teal-700 text-teal-700 hover:bg-teal-50 rounded-2xl font-medium flex items-center justify-center gap-x-2">
                            <span>Browse all available sessions</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Booking Modal -->
    <div id="booking-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="modal bg-white w-full max-w-lg rounded-3xl shadow-xl border border-slate-200 overflow-hidden">
            <div class="px-6 pt-5 pb-4 border-b flex items-center justify-between bg-slate-50">
                <div>
                    <h3 class="font-semibold text-xl" id="modal-course-name"></h3>
                    <p class="text-sm text-slate-600" id="modal-session-info"></p>
                </div>
                <button class="text-slate-400 hover:text-slate-600 w-9 h-9 flex items-center justify-center">
                    <i class="fa-solid fa-times text-xl"></i>
                </button>
            </div>
            
            <div class="p-6 space-y-5">
                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div class="bg-slate-50 rounded-2xl p-3">
                        <div class="text-xs text-slate-500">VENUE</div>
                        <div id="modal-venue" class="font-medium"></div>
                    </div>
                    <div class="bg-slate-50 rounded-2xl p-3">
                        <div class="text-xs text-slate-500">INSTRUCTOR</div>
                        <div id="modal-instructor" class="font-medium"></div>
                    </div>
                </div>
                
                <div>
                    <label class="text-xs font-semibold tracking-wider text-slate-500 block mb-1.5">YOUR FULL NAME <span class="text-red-500">*</span></label>
                    <input id="book-name" type="text" class="w-full border border-slate-300 focus:border-teal-600 px-4 py-3 rounded-2xl text-sm" placeholder="Dr. Tan Wei Ming">
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-xs font-semibold tracking-wider text-slate-500 block mb-1.5">EMAIL ADDRESS <span class="text-red-500">*</span></label>
                        <input id="book-email" type="email" class="w-full border border-slate-300 focus:border-teal-600 px-4 py-3 rounded-2xl text-sm" placeholder="name@hospital.sg">
                    </div>
                    <div>
                        <label class="text-xs font-semibold tracking-wider text-slate-500 block mb-1.5">DEPARTMENT / UNIT <span class="text-red-500">*</span></label>
                        <input id="book-unit" type="text" list="unit-list" class="w-full border border-slate-300 focus:border-teal-600 px-4 py-3 rounded-2xl text-sm" placeholder="Emergency Department">
                        <datalist id="unit-list">
                            <option value="Emergency Department">
                            <option value="Intensive Care Unit (ICU)">
                            <option value="General Ward - Ward 3">
                            <option value="General Ward - Ward 7">
                            <option value="Operating Theatre">
                            <option value="Outpatient Clinic">
                            <option value="Ambulance / Paramedic">
                            <option value="Training &amp; Education">
                            <option value="Other">
                        </option></datalist>
                    </div>
                </div>
                
                <div class="pt-2 flex items-center justify-between text-xs">
                    <div class="flex items-center gap-x-2 text-emerald-600">
                        <i class="fa-solid fa-check-circle"></i>
                        <span id="modal-slots-left" class="font-semibold"></span>
                    </div>
                    <button class="text-teal-600 hover:text-teal-700 text-xs flex items-center gap-x-1 font-medium">
                        <i class="fa-solid fa-magic"></i>
                        <span>Fill demo data</span>
                    </button>
                </div>
            </div>
            
            <div class="px-6 py-4 bg-slate-50 border-t flex gap-x-3">
                <button class="flex-1 py-3 text-sm font-semibold border border-slate-300 rounded-2xl hover:bg-white transition-colors">Cancel</button>
                <button class="flex-1 py-3 text-sm font-semibold bg-teal-700 hover:bg-teal-800 text-white rounded-2xl transition-colors">Confirm Booking</button>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toast-container" class="fixed bottom-5 right-5 z-[200] flex flex-col gap-y-2"></div>

    <!-- Admin Panel Modal -->
    <div id="admin-modal" class="hidden fixed inset-0 bg-black/70 backdrop-blur z-[150] flex items-center justify-center p-4">
        <div class="modal bg-white w-full max-w-7xl max-h-[92vh] rounded-3xl shadow-2xl flex flex-col overflow-hidden">
            
            <!-- Admin Header -->
            <div class="px-7 py-4 border-b flex items-center justify-between bg-slate-900 text-white">
                <div class="flex items-center gap-x-3">
                    <i class="fa-solid fa-shield-halved text-emerald-400 text-xl"></i>
                    <div>
                        <span class="font-semibold tracking-tight">Administrator Dashboard</span>
                        <span class="ml-3 text-xs px-2.5 py-0.5 bg-emerald-900 text-emerald-400 rounded">DEMO MODE</span>
                    </div>
                </div>
                <div class="flex items-center gap-x-2">
                    <button class="text-xs flex items-center gap-x-1.5 px-3 py-1.5 bg-slate-800 hover:bg-slate-700 transition-colors rounded-2xl">
                        <i class="fa-solid fa-sync-alt"></i>
                        <span>Reset Demo Data</span>
                    </button>
                    <button class="w-9 h-9 flex items-center justify-center text-slate-400 hover:text-white">
                        <i class="fa-solid fa-times text-2xl"></i>
                    </button>
                </div>
            </div>
            
            <div class="flex-1 overflow-auto p-6">
                <!-- Admin Stats -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                    <div class="bg-slate-50 border border-slate-100 p-4 rounded-2xl">
                        <div class="text-xs text-slate-500">TOTAL SESSIONS</div>
                        <div id="admin-stat-sessions" class="text-3xl font-semibold text-slate-800">14</div>
                    </div>
                    <div class="bg-slate-50 border border-slate-100 p-4 rounded-2xl">
                        <div class="text-xs text-slate-500">TOTAL BOOKINGS</div>
                        <div id="admin-stat-bookings" class="text-3xl font-semibold text-slate-800">87</div>
                    </div>
                    <div class="bg-slate-50 border border-slate-100 p-4 rounded-2xl">
                        <div class="text-xs text-slate-500">SLOTS FILLED</div>
                        <div id="admin-stat-filled" class="text-3xl font-semibold text-slate-800">142 / 198</div>
                    </div>
                    <div class="bg-slate-50 border border-slate-100 p-4 rounded-2xl">
                        <div class="text-xs text-slate-500">OCCUPANCY RATE</div>
                        <div id="admin-stat-rate" class="text-3xl font-semibold text-emerald-600">71.7%</div>
                    </div>
                </div>
                
                <!-- Admin Sub Navigation -->
                <div class="flex border-b mb-5">
                    <button id="admin-subtab-0" class="admin-subtab active px-5 py-2 text-sm font-semibold border-b-2 border-teal-700 text-teal-700">Manage Sessions</button>
                    <button id="admin-subtab-1" class="admin-subtab px-5 py-2 text-sm font-semibold text-slate-600">All Bookings</button>
                    <button id="admin-subtab-2" class="admin-subtab px-5 py-2 text-sm font-semibold text-slate-600">Reports &amp; Export</button>
                </div>
                
                <!-- SUBTAB 0: Manage Sessions -->
                <div id="admin-subview-0">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="font-semibold">Scheduled Training Sessions</h4>
                        <button class="px-4 py-2 text-sm font-semibold flex items-center gap-x-2 bg-teal-700 hover:bg-teal-800 text-white rounded-2xl">
                            <i class="fa-solid fa-plus"></i>
                            <span>Add New Session</span>
                        </button>
                    </div>
                    
                    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
                        <table class="w-full text-sm">
                            <thead class="bg-slate-100">
                                <tr>
                                    <th class="px-4 py-3 text-left font-semibold text-xs text-slate-600">DATE</th>
                                    <th class="px-4 py-3 text-left font-semibold text-xs text-slate-600">COURSE</th>
                                    <th class="px-4 py-3 text-left font-semibold text-xs text-slate-600">VENUE</th>
                                    <th class="px-4 py-3 text-left font-semibold text-xs text-slate-600">INSTRUCTOR</th>
                                    <th class="px-4 py-3 text-center font-semibold text-xs text-slate-600 w-24">SLOTS</th>
                                    <th class="px-4 py-3 text-center font-semibold text-xs text-slate-600 w-20">BOOKED</th>
                                    <th class="px-4 py-3 w-36"></th>
                                </tr>
                            </thead>
                            <tbody id="admin-sessions-tbody" class="divide-y text-sm">
                                <!-- JS -->
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <!-- SUBTAB 1: All Bookings -->
                <div id="admin-subview-1" class="hidden">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex-1 max-w-xs">
                            <input id="admin-booking-search" type="text" placeholder="Search name, email or unit..." class="w-full text-sm border border-slate-300 px-4 py-2 rounded-2xl">
                        </div>
                        <button class="text-sm flex items-center px-4 py-2 gap-x-2 border border-slate-300 rounded-2xl hover:bg-slate-50">
                            <i class="fa-solid fa-download"></i>
                            <span>Export CSV</span>
                        </button>
                    </div>
                    
                    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden max-h-[420px] overflow-y-auto">
                        <table class="w-full text-sm">
                            <thead class="bg-slate-100 sticky top-0">
                                <tr>
                                    <th class="px-4 py-3 text-left font-semibold text-xs text-slate-600">NAME</th>
                                    <th class="px-4 py-3 text-left font-semibold text-xs text-slate-600">EMAIL</th>
                                    <th class="px-4 py-3 text-left font-semibold text-xs text-slate-600">UNIT</th>
                                    <th class="px-4 py-3 text-left font-semibold text-xs text-slate-600">COURSE / DATE</th>
                                    <th class="px-4 py-3 text-xs text-center font-semibold text-slate-600">BOOKED ON</th>
                                    <th class="px-4 py-3 w-16"></th>
                                </tr>
                            </thead>
                            <tbody id="admin-bookings-tbody" class="divide-y">
                                <!-- JS populated -->
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <!-- SUBTAB 2: Reports -->
                <div id="admin-subview-2" class="hidden">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <div>
                            <h5 class="font-semibold mb-3">Occupancy by Course</h5>
                            <div class="bg-white border border-slate-200 rounded-2xl p-5 h-80">
                                <canvas id="admin-occupancy-chart"></canvas>
                            </div>
                        </div>
                        <div>
                            <h5 class="font-semibold mb-3">Monthly Booking Trend</h5>
                            <div class="bg-white border border-slate-200 rounded-2xl p-5 h-80">
                                <canvas id="admin-trend-chart"></canvas>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-6">
                        <button class="px-5 py-2.5 text-sm border border-slate-300 rounded-2xl flex items-center gap-x-2 hover:bg-white">
                            <i class="fa-solid fa-file-export"></i>
                            <span>Export All Sessions (CSV)</span>
                        </button>
                        <span class="text-xs text-slate-500 ml-4">Data is stored locally in this browser for demo purposes.</span>
                    </div>
                </div>
            </div>
            
            <div class="px-6 py-3 bg-slate-50 text-xs text-slate-500 border-t flex items-center justify-between">
                <div>Prototype v1.2 • Data persists in browser localStorage • For production use a secure backend</div>
                <div class="cursor-pointer hover:text-slate-700">Close</div>
            </div>
        </div>
    </div>

    <!-- Session Edit/Add Modal -->
    <div id="session-modal" class="hidden fixed inset-0 bg-black/60 z-[160] flex items-center justify-center p-4">
        <div class="modal bg-white w-full max-w-md rounded-3xl overflow-hidden border border-slate-200">
            <div class="px-6 py-4 border-b bg-slate-50 flex justify-between items-center">
                <h3 id="session-modal-title" class="font-semibold text-lg">Add New Session</h3>
                <button class="text-xl leading-none text-slate-400 hover:text-red-500">&times;</button>
            </div>
            <div class="p-6 space-y-4 text-sm">
                <div>
                    <label class="text-xs font-semibold text-slate-500 block mb-1">COURSE TYPE</label>
                    <select id="sess-course" class="w-full border border-slate-300 px-3 py-2.5 rounded-2xl">
                        <option value="Wilderness Medical First Responder">Wilderness Medical First Responder</option>
                        <option value="Standard First Aid">Standard First Aid</option>
                        <option value="Basic Cardiac Life Support + AED">Basic Cardiac Life Support + AED</option>
                    </select>
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-xs font-semibold text-slate-500 block mb-1">DATE</label>
                        <input id="sess-date" type="date" class="w-full border border-slate-300 px-3 py-2.5 rounded-2xl">
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-slate-500 block mb-1">TIME</label>
                        <input id="sess-time" type="text" placeholder="08:30 - 17:30" class="w-full border border-slate-300 px-3 py-2.5 rounded-2xl">
                    </div>
                </div>
                
                <div>
                    <label class="text-xs font-semibold text-slate-500 block mb-1">VENUE</label>
                    <input id="sess-venue" type="text" class="w-full border border-slate-300 px-3 py-2.5 rounded-2xl" placeholder="Training Room 2, Level 4">
                </div>
                
                <div>
                    <label class="text-xs font-semibold text-slate-500 block mb-1">INSTRUCTOR(S)</label>
                    <input id="sess-instructor" type="text" class="w-full border border-slate-300 px-3 py-2.5 rounded-2xl" placeholder="Sr. Nurse Aisha Rahman">
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-xs font-semibold text-slate-500 block mb-1">MAX SLOTS</label>
                        <input id="sess-slots" type="number" min="4" max="30" value="12" class="w-full border border-slate-300 px-3 py-2.5 rounded-2xl">
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-slate-500 block mb-1">CURRENTLY BOOKED</label>
                        <input id="sess-booked" type="number" min="0" value="0" class="w-full border border-slate-300 px-3 py-2.5 rounded-2xl">
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 bg-slate-50 flex gap-x-3 border-t">
                <button class="flex-1 py-2.5 text-sm font-medium border border-slate-300 rounded-2xl">Cancel</button>
                <button id="session-save-btn" class="flex-1 py-2.5 text-sm font-semibold bg-teal-700 text-white rounded-2xl">Save Session</button>
            </div>
        </div>
    </div>

    <footer class="text-center text-xs text-slate-400 py-6">
        MS&amp;T Medical Services &amp; Training • Internal Booking System Prototype • Built for departmental use
    </footer>

    
</body>
</html>
